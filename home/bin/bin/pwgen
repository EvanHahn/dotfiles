#!/usr/bin/env python3
import argparse
import secrets
import string

DEFAULT_ALPHABET = string.ascii_uppercase + string.digits + "!@#$%^&*()-_=+[]{};:,.<>"
PREDEFINED_ALPHABETS = {
    "alpha": string.ascii_letters,
    "numeric": string.digits,
    "alphanum": string.ascii_letters + string.digits,
}


def build_alphabet(alphabet_type):
    alphabet = PREDEFINED_ALPHABETS.get(alphabet_type, alphabet_type)
    return list(frozenset(alphabet))


def generate_password(length, alphabet):
    return "".join(secrets.choice(alphabet) for _ in range(length))


def main():
    parser = argparse.ArgumentParser()
    parser.add_argument("--length", "-l", type=int, default=64, help="length")
    parser.add_argument(
        "--alphabet",
        "-a",
        default=DEFAULT_ALPHABET,
        help=(f"Alphabet or {"|".join(PREDEFINED_ALPHABETS.keys())}"),
    )
    args = parser.parse_args()

    alphabet = build_alphabet(args.alphabet)

    if args.length < 1:
        parser.error("Length must be at least 1")
    if not alphabet:
        parser.error("Alphabet cannot be empty")

    print(generate_password(args.length, alphabet))


if __name__ == "__main__":
    main()
