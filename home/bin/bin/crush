#!/usr/bin/env python3
from argparse import ArgumentParser
from concurrent.futures import ThreadPoolExecutor
import subprocess
import sys
from pathlib import Path
from tempfile import TemporaryDirectory
from typing import Optional


def eprint(*args):
    print(*args, file=sys.stderr)


def run(cmd: list[str], out: Path) -> bool:
    try:
        subprocess.run(cmd, check=True, stdout=out.open("wb"), stderr=subprocess.PIPE)
        return True
    except FileNotFoundError:
        eprint(f"{cmd[0]} not available, skipping")
        return False
    except subprocess.CalledProcessError as e:
        eprint(f"{cmd[0]} failed: {e.stderr.decode()}")
        return False


def gzip(input_file: Path, working_dir: Path) -> Optional[Path]:
    result = working_dir / (input_file.name + ".gz")
    return result if run(["gzip", "-9", "-c", str(input_file)], result) else None


def bzip2(input_file: Path, working_dir: Path) -> Optional[Path]:
    result = working_dir / (input_file.name + ".bz2")
    return result if run(["bzip2", "-c", str(input_file)], result) else None


def xz(input_file: Path, working_dir: Path) -> Optional[Path]:
    result = working_dir / (input_file.name + ".xz")
    if run(
        ["xz", "--lzma2=dict=1GiB,nice=273,depth=1000,mf=bt4", "-c", str(input_file)],
        result,
    ):
        return result
    return None


def brotli(input_file: Path, working_dir: Path) -> Optional[Path]:
    result = working_dir / (input_file.name + ".br")
    return result if run(["brotli", "-c", str(input_file)], result) else None


def zstd(input_file: Path, working_dir: Path) -> Optional[Path]:
    result = working_dir / (input_file.name + ".zst")
    if run(["zstd", "--ultra", "-22", "-c", str(input_file)], result):
        return result
    return None


def size(p: Path) -> int:
    return p.stat().st_size


def get_best(input_file: Path, working_dir: Path) -> Optional[Path]:
    compressors = [gzip, bzip2, xz, brotli, zstd]

    with ThreadPoolExecutor() as executor:
        candidates = executor.map(lambda c: c(input_file, working_dir), compressors)
    candidates = filter(lambda c: c, candidates)

    return min(candidates, key=size, default=None)


def main() -> None:
    parser = ArgumentParser(
        description="Pick the smallest compression from gzip, bzip2, xz, and others."
    )
    parser.add_argument("input_file", type=Path)
    input_file = parser.parse_args().input_file

    with TemporaryDirectory() as temp_dir_string:
        temp_dir = Path(temp_dir_string)

        best = get_best(input_file, temp_dir)

        if not best:
            eprint("All compressors failed")
            sys.exit(1)

        if size(best) >= size(input_file):
            eprint("Couldn't shrink the file")
            sys.exit(1)

        best.replace(input_file.parent / best.name)


if __name__ == "__main__":
    main()
