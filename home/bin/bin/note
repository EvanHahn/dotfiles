#!/usr/bin/env python3
import argparse
import os
from pathlib import Path
import subprocess
from datetime import datetime


def parse_date_prefix(s):
    try:
        return datetime.strptime(s[:10], "%Y-%m-%d")
    except ValueError:
        return None


def parse_title(title):
    title = title.strip().replace("/", "_").replace("\\", "_").replace(":", "-")
    date_prefix = parse_date_prefix(title)
    if date_prefix:
        return (date_prefix, title[10:].strip())
    return (datetime.now(), title)


def get_filename(date, title):
    date_str = date.strftime("%Y-%m-%d")
    if title == "":
        return f"{date_str}.md"
    return f"{date_str} {title}.md"


def get_editor():
    return os.getenv("VISUAL") or os.getenv("EDITOR") or "vim"


def main():
    parser = argparse.ArgumentParser()
    parser.add_argument("title", nargs="?", default="", help="Note title")
    parser.add_argument(
        "-a", "--archive", action="store_true", help="Put note in archive instead"
    )
    args = parser.parse_args()

    date, title = parse_title(args.title)
    filename = get_filename(date, title)

    notes_path = Path.home() / "notes"
    path = notes_path
    if args.archive:
        path /= "archive"
        path /= date.strftime("%Y")
    path.mkdir(mode=0o700, parents=True, exist_ok=True)

    path /= filename

    path.touch()
    subprocess.run([get_editor(), path], cwd=notes_path, check=True)


if __name__ == "__main__":
    main()
